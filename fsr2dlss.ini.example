; fsr2dlss configuration. Rename to fsr2dlss.ini and place it next to amd_fidelityfx_dx12.dll
; (the game's Win64 folder). Lines starting with ; or # are comments. Read once at startup.

[FrameGen]
; Frame-generation multiplier: 2 = 2x, 3 = 3x, 4 = 4x. 3x and 4x are Multi-Frame Generation and
; need an RTX 50-series card. The value is clamped down to whatever the card reports as its maximum.
Multiplier = 3

; Flip metering:
;   hardware = the Blackwell display engine paces the generated frames (true 3x/4x MFG). Recommended.
;   software = block NvAPI_D3D12_SetFlipConfig so DLSS-G uses its software pacer (clean 2x only).
FlipMetering = hardware

[Upscaling]
; DLSS super-resolution in place of the game's FSR upscaler.
;   true  = DLSS. The quality mode is picked from the in-game FSR preset / render resolution.
;   false = leave the upscale as FSR.
DLSS = true

[Overlay]
; Make the Steam overlay report "DLSS" with the correct native/generated frame counts. This only
; affects what Steam displays; the actual DLSS output is the same either way. Set false and Steam
; will call it "FSR".
SteamOverlayFix = true

[HUD]
; Experimental. Tag a HUD-less color and UI layer for DLSS-G. Lies of P bakes the UI into the frame,
; so this does not help there. Leave off.
HudlessTags = false

[Logging]
; Write ffx_bridge.log next to the mod. Off by default so a normal install adds no extra files.
; Turn on only when troubleshooting.
Debug = false
